# ================================================
# 环境变量配置文件示例
# 复制此文件为 .env 并修改相应的值
# ================================================

# ================================================
# 服务器基础配置
# ================================================
NODE_ENV=development
PORT=3000
TIMEZONE=Asia/Shanghai
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# ================================================
# 数据库配置（MySQL）
# ================================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_database_password
DB_NAME=miniprogram_db
DB_POOL_SIZE=20
DB_CONNECT_TIMEOUT=10000

# ================================================
# JWT身份验证配置
# ================================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# ================================================
# 微信小程序配置
# ================================================
WX_APP_ID=your_wechat_app_id
WX_APP_SECRET=your_wechat_app_secret

# ================================================
# 微信支付配置
# ================================================
PAYMENT_SIMULATE=true
WX_PAY_MCH_ID=your_wechat_pay_mch_id
WX_PAY_SERIAL_NO=your_wechat_pay_serial_no
WX_PAY_APIV3_KEY=your_wechat_pay_apiv3_key
WX_PAY_CERT_PATH=./cert/apiclient_cert.pem
WX_PAY_KEY_PATH=./cert/apiclient_key.pem
WX_PAY_NOTIFY_URL=https://your-api-domain.com/api/order/pay/notify

# ================================================
# Redis缓存配置（可选）
# ================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ================================================
# API签名验证配置
# ================================================
# API_SIGNATURE_SECRET=your-api-signature-secret-key-min-32-chars
# SKIP_API_SIGNATURE=false

# ================================================
# 腾讯云短信配置
# ================================================
# TENCENT_SECRET_ID=your-tencent-secret-id
# TENCENT_SECRET_KEY=your-tencent-secret-key
# TENCENT_SMS_APP_ID=your-sms-app-id
# TENCENT_SMS_SIGN_NAME=你的短信签名
# TENCENT_SMS_TEMPLATE_ID=your-template-id
# TENCENT_SMS_REGION=ap-guangzhou

# ================================================
# 其他配置
# ================================================
WECHAT_DOWNLOAD_DOMAIN=https://mmbiz.qpic.cn