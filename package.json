{
  "name": "miniprogram-api-server",
  "version": "1.0.0",
  "description": "微信小程序后端API服务器",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --detectOpenHandles --forceExit",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write .",
    "build": "npm run lint && npm run test",
    "debug": "node --inspect server.js",
    "health": "node -e \"require('./config/mysql').testConnection().then(() => console.log('✅ 数据库连接成功')).catch(err => console.log('❌ 数据库连接失败:', err))\""
  },
  "keywords": [
    "miniprogram",
    "api",
    "express"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.15.0",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "joi": "^18.1.2",
    "jsonwebtoken": "^9.0.0",
    "multer": "^2.1.1",
    "mysql2": "^3.20.0",
    "redis": "^5.12.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tencentcloud-sdk-nodejs-captcha": "^4.1.191",
    "uuid": "^9.0.0",
    "wechatpay-node-v3": "^2.2.1",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "nodemon": "^2.0.22",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2"
  }
}
